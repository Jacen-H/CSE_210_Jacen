class Comment:
    def __init__(self, name, text):
        self.name = name
        self.text = text

class Video:
    def __init__(self, title, author, length):
        self.title = title
        self.author = author
        self.length = length
        self.comments = []

    def add_comment(self, comment):
        self.comments.append(comment)

    def get_comment_count(self):
        return len(self.comments)

def main():
    videos = []

    v1 = Video("Modern CSS Layouts", "DevGuru", 640)
    v1.add_comment(Comment("Alice", "The section on Grid was so helpful!"))
    v1.add_comment(Comment("Bob", "I finally understand the difference between Flexbox and Grid."))
    v1.add_comment(Comment("Charlie", "Great production quality."))
    videos.append(v1)

    v2 = Video("Database Design 101", "DataWiz", 1200)
    v2.add_comment(Comment("Dave", "Foreign keys always confused me until now."))
    v2.add_comment(Comment("Eve", "Could you do a video on CTEs next?"))
    v2.add_comment(Comment("Frank", "Clear and concise explanation."))
    videos.append(v2)

    v3 = Video("Tabletop Mechanics", "GameMaker", 900)
    v3.add_comment(Comment("Grace", "Love the dice-rolling logic here."))
    v3.add_comment(Comment("Heidi", "Adding this to my homebrew campaign."))
    v3.add_comment(Comment("Ivan", "The math behind the crits is fascinating."))
    videos.append(v3)

    for video in videos:
        print("-" * 40)
        print(f"Title: {video.title}")
        print(f"Author: {video.author}")
        print(f"Length: {video.length} seconds")
        print(f"Number of Comments: {video.get_comment_count()}")
        print("\nComments:")
        
        for comment in video.comments:
            print(f"- {comment.name}: {comment.text}")
        print()

if __name__ == "__main__":
    main()
