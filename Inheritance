class Animal:
    def __init__(self, name):
        self.name = name

    def speak(self):
        print("The animal makes a sound.")

class Dog(Animal):
    def speak(self):
        print(self.name + " says: Woof!")

class Cat(Animal):
    def speak(self):
        print(self.name + " says: Meow!")

dog1 = Dog("Buddy")
cat1 = Cat("Whiskers")

dog1.speak()
cat1.speak()
